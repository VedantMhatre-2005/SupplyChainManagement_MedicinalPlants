# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Your MetaMask / wallet private key (without 0x prefix is fine)
PRIVATE_KEY=your_private_key_here

# Alchemy RPC URL for Sepolia testnet
# Get one free at https://www.alchemy.com
ALCHEMY_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_api_key

# Etherscan API key for contract verification (optional)
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here
