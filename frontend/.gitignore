# ============================================================================
# Frontend React App .gitignore
# ============================================================================

# ── Dependencies ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.lock

# ── Build & Production ────────────────────────────────────────────────────
build/
dist/
.next/
out/

# ── Environment & Secrets ────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── React & Node ─────────────────────────────────────────────────────────
.eslintcache
.stylelintcache

# ── IDE ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────
logs/
*.log

# ── Testing ───────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Python ───────────────────────────────────────────────────────────────
.venv/
venv/
ENV/
